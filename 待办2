# 🚀 适配你的 Service 层的完整改造方案
结合你提供的 `BookService`、`BookServiceImpl`、`BookMapper` 和通用返回类 `R`，我会帮你完成**控制器、前端代码的全量适配改造**，确保「分类筛选、关键词搜索、分页展示」功能完整可用，且权限控制逻辑（普通用户/管理员）完全生效。

## 一、第一步：改造 BookController.java（核心适配）
适配你的 `BookService` 中 `pageList` 方法，补充分类/搜索/分页接口，同时兼容权限控制：
```java
package com.whxy.campusbooktrade2.controller;

import com.baomidou.mybatisplus.core.metadata.IPage;
import com.whxy.campusbooktrade2.common.R;
import com.whxy.campusbooktrade2.entity.Book;
import com.whxy.campusbooktrade2.entity.User;
import com.whxy.campusbooktrade2.service.BookService;
import com.whxy.campusbooktrade2.service.UserService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("/book")
public class BookController {
    @Autowired
    private BookService bookService;

    @Autowired
    private UserService userService;

    /**
     * 发布书籍（适配Service层的addBook方法，自动关联当前用户）
     */
    @PostMapping("/add")
    public R<String> add(@RequestBody Book book) {
        // Service层已自动设置userId、createTime、status，此处无需重复设置
        return bookService.addBook(book);
    }

    /**
     * 分页查询书籍（支持分类、关键词搜索）
     * @param page 页码（默认1）
     * @param size 每页条数（默认10）
     * @param category 分类（可选）
     * @param name 书名关键词（可选）
     */
    @GetMapping("/list")
    public R<IPage<Map<String, Object>>> list(
            @RequestParam(defaultValue = "1") Integer page,
            @RequestParam(defaultValue = "10") Integer size,
            @RequestParam(required = false) String category,
            @RequestParam(required = false) String name
    ) {
        // 调用Service的分页查询方法
        IPage<Book> bookPage = bookService.pageList(page, size, category, name);

        // 组装返回数据（补充发布者名称）
        IPage<Map<String, Object>> resultPage = new IPage<Map<String, Object>>() {
            @Override
            public List<Map<String, Object>> getRecords() {
                List<Map<String, Object>> list = new ArrayList<>();
                for (Book book : bookPage.getRecords()) {
                    Map<String, Object> map = new HashMap<>();
                    map.put("id", book.getId());
                    map.put("name", book.getName());
                    map.put("author", book.getAuthor());
                    map.put("price", book.getPrice());
                    map.put("oldLevel", book.getOldLevel());
                    map.put("category", book.getCategory());
                    map.put("userId", book.getUserId());
                    map.put("createTime", book.getCreateTime());

                    // 查询发布者名称
                    User user = userService.getById(book.getUserId());
                    map.put("publisherName", user == null ? "未知用户" : user.getUsername());
                    list.add(map);
                }
                return list;
            }

            @Override
            public long getTotal() {
                return bookPage.getTotal();
            }

            @Override
            public long getSize() {
                return bookPage.getSize();
            }

            @Override
            public long getCurrent() {
                return bookPage.getCurrent();
            }

            @Override
            public long getPages() {
                return bookPage.getPages();
            }
        };
        return R.ok(resultPage);
    }

    /**
     * 获取所有书籍分类（供前端下拉框使用）
     */
    @GetMapping("/categories")
    public R<List<String>> getCategories() {
        // 方式1：固定分类（快速落地）
        List<String> categories = List.of("编程", "文学", "教材", "小说", "社科", "其他");
        // 方式2：从数据库查询所有已存在的分类（更灵活）
        // List<String> categories = bookService.listObjs(query().select("category").groupBy("category")).stream().map(Object::toString).toList();
        return R.ok(categories);
    }

    /**
     * 修改书籍（Service层已做权限控制）
     */
    @PutMapping("/update")
    public R<String> update(@RequestBody Book book) {
        return bookService.updateBook(book);
    }

    /**
     * 删除书籍（Service层已做权限控制）
     */
    @DeleteMapping("/delete/{id}")
    public R<String> delete(@PathVariable Long id) {
        return bookService.deleteBook(id);
    }
}
```

