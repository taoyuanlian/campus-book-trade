<script>
    let token = localStorage.getItem("token");
    let userInfo = {
        userId: localStorage.getItem("userId"),
        username: localStorage.getItem("username"),
        role: localStorage.getItem("role")
    };

    // 新增：分页/搜索/分类参数
    let pageParams = {
        page: 1,          // 页码
        size: 10,         // 每页条数
        category: "",     // 分类
        name: ""          // 书名关键词
    };

    const utils = {
        parseToken: function() {
            if (!token) return false;
            try {
                const payload = JSON.parse(atob(token.split('.')[1]));
                userInfo = {
                    userId: payload.userId,
                    username: payload.username || payload.sub,
                    role: payload.role
                };
                localStorage.setItem("userId", userInfo.userId);
                localStorage.setItem("username", userInfo.username);
                localStorage.setItem("role", userInfo.role);
                return true;
            } catch (e) {
                alert("Token解析失败，请重新登录！");
                this.clearLogin();
                return false;
            }
        },
        clearLogin: function() {
            localStorage.clear();
            window.location.href = "login.html";
        },
        getAjaxHeader: function() {
            return { "token": token };
        },
        handleAjaxError: function(err) {
            if (err.status === 401) {
                alert("登录已过期，请重新登录！");
                this.clearLogin();
            } else {
                alert(`操作失败：${err.statusText || '网络异常'}`);
            }
        }
    };

    $(function () {
        if (!token) {
            alert("请先登录！");
            utils.clearLogin();
            return;
        }
        if (!userInfo.role) {
            if (!utils.parseToken()) return;
        }

        $("#userName").text(`欢迎，${userInfo.username || '普通用户'}`);
        if (userInfo.role === "admin") {
            $("#adminMenu").show();
            $("#adminUserMenu").show();
        }

        // 加载分类列表
        loadCategories();
        // 加载书籍列表（带分页/搜索/分类）
        loadBooks();

        // 搜索按钮事件
        $("#searchBtn").click(function() {
            pageParams.name = $("#keywordInput").val().trim();
            pageParams.category = $("#categorySelect").val() || "";
            pageParams.page = 1; // 搜索后重置到第1页
            loadBooks();
        });

        // 重置按钮事件
        $("#resetBtn").click(function() {
            $("#keywordInput").val("");
            $("#categorySelect").val("");
            pageParams = { page: 1, size: 10, category: "", name: "" };
            loadBooks();
        });

        // 分页-上一页
        $("#prevPage").click(function() {
            if (pageParams.page > 1) {
                pageParams.page--;
                loadBooks();
            } else {
                alert("已经是第一页了！");
            }
        });

        // 分页-下一页
        $("#nextPage").click(function() {
            const totalPage = parseInt($("#totalPage").text());
            if (pageParams.page < totalPage) {
                pageParams.page++;
                loadBooks();
            } else {
                alert("已经是最后一页了！");
            }
        });

        // 发布书籍表单提交
        $('#bookForm').submit(function (e) {
            e.preventDefault();
            const bookData = {
                name: $("input[name='name']").val(),
                author: $("input[name='author']").val(),
                price: $("input[name='price']").val(),
                oldLevel: $("select[name='oldLevel']").val(),
                category: $("select[name='category']").val() // 新增分类字段
                // userId由Service层自动设置，无需传递
            };

            $.ajax({
                url: '/book/add',
                type: 'POST',
                contentType: 'application/json',
                headers: utils.getAjaxHeader(),
                data: JSON.stringify(bookData),
                success: function (res) {
                    if (res.code === 200) {
                        alert("发布成功！");
                        loadBooks();
                        $('#bookForm')[0].reset();
                    } else {
                        alert("发布失败：" + res.msg);
                    }
                },
                error: utils.handleAjaxError
            });
        });

        // 退出登录
        $("#logoutBtn").click(utils.clearLogin);

        // 保存编辑
        $('#saveEditBtn').click(function () {
            const bookData = {
                id: $('#editBookId').val(),
                name: $('#editName').val(),
                author: $('#editAuthor').val(),
                price: $('#editPrice').val(),
                oldLevel: $('#editOldLevel').val(),
                category: $('#editCategory').val() // 新增分类字段
                // userId无需传递，Service层会做权限校验
            };

            $.ajax({
                url: '/book/update',
                type: 'PUT',
                contentType: 'application/json',
                headers: utils.getAjaxHeader(),
                data: JSON.stringify(bookData),
                success: function (res) {
                    if (res.code === 200) {
                        alert("修改成功！");
                        $('#editBookModal').modal('hide');
                        loadBooks();
                    } else {
                        alert("修改失败：" + res.msg);
                    }
                },
                error: utils.handleAjaxError
            });
        });
    });

    /**
     * 加载分类列表
     */
    function loadCategories() {
        $.ajax({
            url: '/book/categories',
            type: 'GET',
            headers: utils.getAjaxHeader(),
            success: function(res) {
                if (res.code === 200) {
                    let html = '<option value="">全部分类</option>';
                    res.data.forEach(cate => {
                        html += `<option value="${cate}">${cate}</option>`;
                    });
                    $("#categorySelect").html(html);
                }
            },
            error: utils.handleAjaxError
        });
    }

    /**
     * 加载书籍列表（支持分页/搜索/分类）
     */
    function loadBooks() {
        $.ajax({
            url: '/book/list',
            type: 'GET',
            headers: utils.getAjaxHeader(),
            data: pageParams, // 传递分页/搜索参数
            success: function (res) {
                let html = "";
                const bookPage = res.data || {};
                const bookList = bookPage.records || [];

                if (Array.isArray(bookList)) {
                    if (bookList.length === 0) {
                        html = '<tr><td colspan="7" class="text-center">暂无书籍数据</td></tr>';
                    } else {
                        bookList.forEach(function (item) {
                            let isSelf = userInfo.userId == item.userId;
                            let isAdmin = userInfo.role === "admin";

                            let btns = `<button class="btn btn-xs btn-primary buy-btn" data-id="${item.id}" data-name="${item.name}" data-price="${item.price}">购买</button>`;

                            if (isSelf || isAdmin) {
                                btns += `
                                    <button class="btn btn-xs btn-warning edit-btn" data-id="${item.id}" data-name="${item.name}" data-author="${item.author}" data-price="${item.price}" data-oldlevel="${item.oldLevel}" data-category="${item.category}">编辑</button>
                                    <button class="btn btn-xs btn-danger delete-btn" data-id="${item.id}">删除</button>
                                `;
                            } else {
                                btns += `<span class="text-muted"> &nbsp; 无权操作</span>`;
                            }

                            html += `<tr>
                                        <td>${item.name || ""}</td>
                                        <td>${item.author || ""}</td>
                                        <td>${item.category || ""}</td>
                                        <td>¥${item.price || 0}</td>
                                        <td>${item.oldLevel || ""}</td>
                                        <td>${item.publisherName || '用户'}</td>
                                        <td>${btns}</td>
                                     </tr>`;
                        });
                    }
                } else {
                    html = '<tr><td colspan="7" class="text-center text-danger">数据加载失败</td></tr>';
                }

                // 渲染书籍列表
                $('#bookList').html(html);
                // 渲染分页信息
                renderPagination(bookPage);
                // 绑定事件
                bindDeleteEvent();
                bindEditEvent();
                bindBuyEvent();
            },
            error: function(err) {
                alert("书籍列表加载失败：" + err.statusText);
                $('#bookList').html('<tr><td colspan="7" class="text-center text-danger">加载失败，请刷新</td></tr>');
            }
        });
    }

    /**
     * 渲染分页控件
     */
    function renderPagination(bookPage) {
        const totalCount = bookPage.total || 0;
        const totalPage = bookPage.pages || 0;
        const currentPage = bookPage.current || 1;

        // 更新分页统计
        $("#totalCount").text(totalCount);
        $("#totalPage").text(totalPage);
        $("#currentPage").text(currentPage);

        // 生成页码（简化版，可扩展为多页码展示）
        let pageHtml = `<li class="active"><a href="javascript:;">${currentPage}</a></li>`;
        $("#pageNumbers").html(pageHtml);
    }

    /**
     * 绑定购买事件
     */
    function bindBuyEvent() {
        $('.buy-btn').click(function () {
            const bookId = $(this).attr('data-id');
            const bookName = $(this).attr('data-name');
            const bookPrice = $(this).attr('data-price');

            if (!confirm(`确定购买《${bookName}》吗？价格：¥${bookPrice}`)) return;

            const orderData = {
                userId: userInfo.userId,
                bookId: bookId,
                price: bookPrice
            };

            $.ajax({
                url: '/order/create',
                type: 'POST',
                contentType: 'application/json',
                headers: utils.getAjaxHeader(),
                data: JSON.stringify(orderData),
                success: function (res) {
                    if (res.code === 200) {
                        alert(res.msg || "下单成功！可前往「我的订单」查看");
                    } else {
                        alert("下单失败：" + res.msg);
                    }
                },
                error: utils.handleAjaxError
            });
        });
    }

    /**
     * 绑定编辑事件（新增分类赋值）
     */
    function bindEditEvent() {
        $('.edit-btn').click(function () {
            const bookId = $(this).attr('data-id');
            $('#editBookId').val(bookId);
            $('#editName').val($(this).attr('data-name'));
            $('#editAuthor').val($(this).attr('data-author'));
            $('#editPrice').val($(this).attr('data-price'));
            $('#editOldLevel').val($(this).attr('data-oldlevel'));
            $('#editCategory').val($(this).attr('data-category')); // 分类赋值
            $('#editBookModal').modal('show');
        });
    }

    /**
     * 绑定删除事件
     */
    function bindDeleteEvent() {
        $('.delete-btn').click(function () {
            if (!confirm("确定要删除该商品吗？删除后无法恢复！")) return;
            const bookId = $(this).attr('data-id');
            if (!bookId) {
                alert("商品ID为空，删除失败！");
                return;
            }

            $.ajax({
                url: '/book/delete/' + bookId,
                type: 'DELETE',
                headers: utils.getAjaxHeader(),
                success: function (res) {
                    if (res.code === 200) {
                        alert("删除成功！");
                        loadBooks();
                    } else {
                        alert("删除失败：" + res.msg);
                    }
                },
                error: utils.handleAjaxError
            });
        });
    }
</script>
</body>
